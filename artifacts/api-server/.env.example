# ClassMind API Server Configuration
# Copy this to .env and fill in your values

# ========== Google OAuth 2.0 ==========
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# ========== Database ==========
# Local Development:
# DATABASE_URL=postgresql://localhost:5432/classmind
#
# Neon (Cloud PostgreSQL - FREE):
# Get from: https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xyz.ap-southeast-1.aws.neon.tech/classmind?sslmode=require

# ========== Security Keys ==========
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=6d31a8b89082a774d8528c3fb70251ff6a6b4be4ab925dbcb95e604d043e7442
JWT_SECRET=d25b015be163ee53038a781188959e2f96a7a8443e402a49f732182395bee7f9
JWT_REFRESH_SECRET=da823d097adf100865fed49ccfd585f291f726c8c1383f2edd45721915f1f4a3
SESSION_SECRET=classmind-super-secret-session-key-2026-production-change-me-32-chars-min

# ========== AI/LLM ==========
# Get free API key: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# ========== Server Configuration ==========
PORT=5000
NODE_ENV=development
BASE_PATH=/api

# ========== CORS (for production) ==========
# Comma-separated list of allowed origins:
# ALLOWED_ORIGINS=https://yourapp.vercel.app,https://custom-domain.com

# ========== Optional: Session Store ==========
# For production, consider using a dedicated session store:
# SESSION_STORE=redis://your-redis-url
